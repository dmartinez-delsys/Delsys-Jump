<UserControl  x:Class="Basic_Streaming.NET.Views.PairSensor"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:local="clr-namespace:Basic_Streaming.NET.Views"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              Height="950"
              d:DesignWidth="400"
              mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="Button"
               x:Key="PrimaryButton">
            <Setter Property="Background"
                    Value="#3D885C" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="DemiBold" />
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#377751" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button"
               x:Key="SecondaryButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="Black" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="Black" />
            <Setter Property="FontWeight"
                    Value="DemiBold" />
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#555D7B"
            Height="180"
            Width="400"
            BorderThickness="1">
        <Grid Background="#555D7B"
              Width="400"
              Height="200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="100" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.ColumnSpan="3"
                       VerticalAlignment="Center"
                       FontWeight="DemiBold"
                       Foreground="White"
                       Text="Pair Sensor"
                       HorizontalAlignment="Left"
                       Margin="15,0,0,0"
                       FontSize="16" />

            <StackPanel Name="MainPanel"
                        Grid.Row="1"
                        Grid.RowSpan="2"
                        Grid.ColumnSpan="3"
                        Background="White"
                        Orientation="Vertical">
                <TextBlock Name="TextBoxForSensorNumberDropDown"
                           Margin="15,10,0,0"
                           HorizontalAlignment="Left"
                           FontFamily="Arial"
                           FontSize="14"
                           FontWeight="DemiBold"
                           Visibility="Visible">
                    Enter a Sensor Number
                </TextBlock>
                <TextBox Name="textbox_ForSensorNumber"
                         Width="300"
                         Height="25"
                         Margin="15 15 0 0"
                         HorizontalAlignment="Left"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial"
                         FontSize="14" />
                <TextBlock Margin="15,10,0,0"
                           Grid.Row="1"
                           Foreground="Red"
                           Visibility="Visible"
                           Name="UserInputLettersErrorMessage"
                           TextAlignment="Left"
                           HorizontalAlignment="Left"
                           Grid.ColumnSpan="3"
                           FontSize="12"
                           FontFamily="Arial" />
            </StackPanel>


            <Button Name="btn_Add"
                    Grid.Column="1"
                    Grid.Row="2"
                    Click="clk_AddSensor"
                    Content="Add Sensor"
                    Height="30"
                    Margin="10,0,0,10"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Grid.Row="2"
                    Grid.Column="2"
                    Click="clk_Finish"
                    Content="Finish"
                    FontSize="14"
                    Height="30"
                    Margin="10,0,10,10"
                    Style="{StaticResource SecondaryButton}" />
        </Grid>
    </Border>
</UserControl>