<UserControl x:Class="Basic_Streaming.NET.Views.StreamInfo"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:ViewModels="clr-namespace:Basic_Streaming.NET.ViewModels"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:local="clr-namespace:Basic_Streaming.NET.Views"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                mc:Ignorable="d">

    <Border Height="500"
            Margin="0,140,0,0"
            BorderBrush="White"
            BorderThickness="2"
            CornerRadius="5"
            Background="White">
        <Grid Name="StreamInfoGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="29*" />
                <ColumnDefinition Width="219*" />
                <ColumnDefinition Width="248*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid.DataContext>
                <ViewModels:StreamInfoVM />
            </Grid.DataContext>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Device Name:"
                       Foreground="Black"
                       Margin="15,0,0,0"
                       TextAlignment="Left"
                       VerticalAlignment="Center"
                       FontWeight="DemiBold"
                       FontSize="14"
                       Grid.ColumnSpan="2" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Pipeline Status:"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Sensors Connected:"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Packets Lost:"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Stream Time:"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Total Channels:"
                       TextAlignment="Left" />



            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       FontWeight="DemiBold"
                       Foreground="Black"
                       Text="Frames Collected:"
                       TextAlignment="Left" />
            
            <TextBlock Name="DeviceName"
                       Grid.Row="0"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       TextAlignment="Left"
                       FontSize="14"
                       Foreground="Black"
                       Text="{Binding StreamInfo.DeviceName}"
                       Margin="15,0,0,0" />

            <TextBlock Name="PipelineStatus"
                       Grid.Row="1"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       FontSize="14"
                       Foreground="Black"
                       Text="{Binding StreamInfo.PipelineStatus}"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="3"
                       Grid.Column="2"
                       Foreground="Black"
                       FontSize="14"
                       Margin="15,0,0,0"
                       TextAlignment="Left"
                       VerticalAlignment="Center"
                       Text="{Binding StreamInfo.TotalChannels}" />

            <TextBlock Grid.Row="2"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="Black"
                       Text="{Binding StreamInfo.SensorsConnected}"
                       Margin="15,0,0,0"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="4"
                       Grid.Column="2"     
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       Foreground="Black"
                       Text="{Binding StreamInfo.StreamTime}"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="5"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       Foreground="Black"
                       Text="{Binding StreamInfo.PacketsLost}"
                       TextAlignment="Left" />

            <TextBlock Grid.Row="6"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="15,0,0,0"
                       Foreground="Black"
                       Text="{Binding StreamInfo.FramesCollected}"
                       TextAlignment="Left" />

        </Grid>
    </Border>
</UserControl>