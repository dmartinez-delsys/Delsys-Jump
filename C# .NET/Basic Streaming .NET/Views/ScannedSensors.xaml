<UserControl
    x:Class="Basic_Streaming.NET.Views.ScannedSensors"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          Name="UC"
          d:DesignHeight="500"
          d:DesignWidth="600"
          mc:Ignorable="d">

    <Border BorderBrush="#555D7B"
            Height="500"
            Margin="10,0,10,0"
            BorderThickness="1"
            CornerRadius="5">
        <Grid Background="#555D7B"
              >
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="30" />
                <RowDefinition />
                <RowDefinition Height="50" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Connected Sensors"
                       Foreground="White"
                       TextAlignment="Left"
                       VerticalAlignment="Center"
                       FontWeight="DemiBold"
                       FontSize="16"
                       Margin="15,10" />

            <Grid Name="LabelPanel"
                        Grid.Row="1"
                        Background="White">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                
                <Label Name="RfLabel"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center"
                       Grid.Column="0">
                    Scanned Rf Sensors
                </Label>
                <Label Grid.Column="1"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center">
                    Scanned Link Sensors
                </Label>
            </Grid>

            <Grid Name="MainPanel"
                        Grid.Row="2"
                        Background="White">
                <Grid.Resources>
                    <Style TargetType="ScrollViewer">
                        <!--  Used to make the scroll bar scroll by pixel rather than by content  -->
                        <Setter Property="CanContentScroll"
                                Value="False" />
                        <Setter Property="HorizontalScrollBarVisibility"
                                Value="Disabled" />
                    </Style>
                </Grid.Resources>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <ListBox Name="ScannedRfSensorsList"
                         Grid.Column="0"
                         HorizontalAlignment="Center"
                         Visibility="Collapsed" />
                <ListBox Name="ScannedLinkSensorsList"
                         Visibility="Collapsed"
                         Grid.Column="1"
                         HorizontalAlignment="Center"/>
            </Grid>

            <Border Name="TriggerPanelBorder"
                    Background="White"
                    Grid.Row="3"
                    BorderBrush="#706C61"
                    BorderThickness="0.5,0.5,0.5,0">

                <StackPanel x:Name="TriggerPanel"
                            HorizontalAlignment="Center"
                            Background="White"
                            Orientation="Horizontal">
                    <CheckBox x:Name="startTriggerCheckbox"
                              VerticalContentAlignment="Center" />
                    <Label VerticalContentAlignment="Center">Start Trigger</Label>
                    <CheckBox x:Name="stopTriggerCheckbox"
                              VerticalContentAlignment="Center" />
                    <Label VerticalContentAlignment="Center">Stop Trigger</Label>
                </StackPanel>
            </Border>

            <Button Grid.Row="4"
                    Name="btn_ArmPipeline"
                    Content="Arm Pipeline"
                    Click="clk_ArmPipeline"
                    FontSize="14"
                    FontWeight="DemiBold"
                    BorderThickness="0"
                    Background="#3D885C"
                    Foreground="White" />
        </Grid>
    </Border>

</UserControl>