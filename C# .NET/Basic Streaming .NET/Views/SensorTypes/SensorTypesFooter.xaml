<UserControl
    x:Class="Basic_Streaming_.NET.Views.SensorTypes.SensorTypesFooter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Basic_Streaming_.NET.Views.SensorTypes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Button
            Name="btn_Scan"
            Grid.Row="0"
            Height="50"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="#377751"
            BorderBrush="White"
            BorderThickness="1"
            Content="Scan"
            FontWeight="DemiBold"
            Foreground="White" />
        <Button
            Name="btn_GoBack"
            Grid.Row="1"
            Height="50"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="#377751"
            BorderBrush="White"
            BorderThickness="1"
            Content="Go Back"
            FontWeight="DemiBold"
            Foreground="White" />
    </Grid>
</UserControl>
