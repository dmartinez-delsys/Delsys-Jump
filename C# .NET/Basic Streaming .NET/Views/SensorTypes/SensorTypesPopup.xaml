<UserControl
    x:Class="Basic_Streaming.NET.Views.SensorTypesPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="50"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <Grid
        Name="SelectTypesGrid"
        Width="300"
        Height="50"
        VerticalAlignment="Stretch"
        Background="White"
        IsEnabled="True"
        Visibility="Visible">

        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Label
            Grid.Row="0"
            Padding="12"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Center"
               Background="#555D7B"
            FontWeight="DemiBold"
            FontSize="18"
            Foreground="White">
            Select Sensor Types
        </Label>
    </Grid>
</UserControl>
