<UserControl
    x:Class="Basic_Streaming_.NET.Views.SensorTypesButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Basic_Streaming_.NET.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="50"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <ToggleButton
        Name="Button"
        Height="50"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Center"
        Background="White"
        BorderBrush="White"
        BorderThickness="1"
        FontWeight="DemiBold"
        Foreground="{Binding MainForegroundColor}" />
</UserControl>
