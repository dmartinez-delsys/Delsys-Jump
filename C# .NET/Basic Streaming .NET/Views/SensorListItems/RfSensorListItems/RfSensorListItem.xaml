<UserControl
    x:Class="Basic_Streaming.NET.Views.SensorListItems.RfSensorListItems.RfSensorListItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="160"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <!--  Rf Sensors: One mode selection, select/deselect sensor, sensor number  -->
    <Grid
        Name="ListItem"
        Width="600"
        Background="White"
        MouseLeftButtonDown="clk_SensorListItem">

        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" HorizontalAlignment="Left"
              Margin="5,0,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox
                Name="SelectCheckBox"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                
                BorderBrush="Black" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="15"
                Text="{Binding Sensor.SensorName}" />
        </Grid>

        <Grid
            Name="ModeRows"
            Grid.Row="1"
            Height="40"
            HorizontalAlignment="Left"
            Margin="5,0,0,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Name="Row0" Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="15"
                           Text="Mode:" />
                <ComboBox
                    x:Name="ModeList"
                    Grid.Column="1"
                    Height="20"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Modes}"
                          SelectedIndex="0">

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ModeName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Grid>

        <StackPanel Name="SensorNumberRow"
                    Grid.Row="2"
                    Margin="5,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock FontSize="15"
                       Text="Sensor Number:" />
            <TextBlock FontSize="15"
                       Margin="10,0,0,0"
                       Text="{Binding Sensor.PairNum}" />
        </StackPanel>
        <StackPanel Name="SensorIDRow"
                    Grid.Row="3"
                    Margin="5,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock FontSize="15"
                       Text="Sensor ID:" />
            <TextBlock Margin="10,0,0,0"
                       FontSize="15"
                       Text="{Binding Sensor.SensorId}" />
        </StackPanel>
    </Grid>
</UserControl>
