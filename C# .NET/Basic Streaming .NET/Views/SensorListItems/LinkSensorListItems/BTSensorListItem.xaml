<UserControl
    x:Class="Basic_Streaming.NET.Views.SensorListItems.LinkSensorListItems.BTSensorListItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Basic_Streaming.NET.Views.SensorListItems"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="80"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <!--  ANT Sensor UI: Remove sensor  -->
    <Grid
        Name="ListItem"
        Width="300"
        Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" HorizontalAlignment="Left">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Name="Remove"
                Grid.Column="0"
                Width="15"
                Height="15"
                Margin="0,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="Red"
                BorderBrush="DarkRed"
                BorderThickness="0.5"
                Click="clk_Remove"
                Content="X"
                FontSize="10"
                Foreground="Black" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="15"
                Text="{Binding Sensor.SensorName}" />
        </Grid>

        <StackPanel
            Name="SensorIDRow"
            Grid.Row="1"
            Margin="5"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock FontSize="15" Text="Sensor ID:" />
            <TextBlock
                Margin="10,0,0,0"
                FontSize="15"
                Text="{Binding Sensor.SensorId}" />
        </StackPanel>
    </Grid>
</UserControl>
