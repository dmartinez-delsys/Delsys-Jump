<Window x:Class="Basic_Streaming.NET.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:Basic_Streaming.NET"
         mc:Ignorable="d"
         Title="Basic Streaming App"
         Height="720"
         Width="1350"
         MinWidth="1350"
         WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="Button"
               x:Key="PrimaryButton">
            <Setter Property="Background"
                    Value="#3D885C" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#3D885C" />
            <Setter Property="FontWeight"
                    Value="DemiBold" />
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#377751" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button"
               x:Key="SecondaryButton">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="DemiBold" />
            <Setter Property="Margin"
                    Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </Window.Resources>

    <DockPanel>
        <Grid DockPanel.Dock="Top"
              Height="50"
              Background="#555D7B">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Delsys API - .NET Basic Streaming"
                       VerticalAlignment="Center"
                       Margin="10"
                       Foreground="White"
                       FontWeight="DemiBold"
                       FontSize="18" />
        </Grid>

        <Border Background="#1F253D"
                ClipToBounds="True">

            <Border Background="Transparent"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Margin="0">

                <Grid Name="MainPanel">
                    <Border Name="MainWindowBorder"
                            Margin="150">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Image Grid.Row="0"
                                   Source="delsys-logo.png"
                                   Width="350" />

                            <Border Grid.Row="1"
                                    BorderBrush="White"
                                    CornerRadius="5"
                                    BorderThickness="2"
                                    Height="150"
                                    Width="500">

                                <Grid Grid.Row="1"
                                      Name="MainWindowGrid"
                                      Background="White">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Name="MainWindowText"
                                               Grid.Row="0"
                                               Text="Please choose a streaming type:"
                                               FontSize="16"
                                               FontWeight="DemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="10" />

                                    <Button Name="btn_DeviceStreaming"
                                            Grid.Row="1"
                                            Content="Device Streaming"
                                            Click="clk_DeviceStreaming"
                                            FontSize="12"
                                            Width="175"
                                            Height="40"
                                            Style="{StaticResource PrimaryButton}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

    </DockPanel>
</Window>