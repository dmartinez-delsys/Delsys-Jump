<UserControl x:Class="Basic_Streaming.NET.DeviceStreaming"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:local="clr-namespace:Basic_Streaming.NET"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <Style TargetType="Button"
               x:Key="BasicStreamingButton">
            <Setter Property="Background"
                    Value="#3D885C" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="DemiBold" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Background"
                                        Value="White" />
                                <Setter Property="Foreground"
                                        Value="Black" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#377751" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Name="Screen">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Height="500"
                CornerRadius="5"
                BorderBrush="#032E63"
                BorderThickness="1">
            <Grid Background="#1F253D">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Button Name="btn_LoadDevice"
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Margin="1"
                        Click="clk_LoadDevice"
                        Content="Load Trigno Device"
                        
                        Style="{StaticResource BasicStreamingButton}" />
                <Button Name="btn_PairSensors"
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="1"
                        Click="clk_Pair"
                        Content="Pair Additional Sensors"
                        IsEnabled="False"
                        Style="{StaticResource BasicStreamingButton}"/>
                <Grid Name="btn_ScanSensors"
                      Grid.Row="1"
                      Grid.Column="1"
                      IsEnabled="False">

                    <Button Margin="1"
                            HorizontalAlignment="Stretch"
                            Panel.ZIndex="0"
                            Click="clk_Scan"
                            Content="Scan for Connected Sensors"
                            Style="{StaticResource BasicStreamingButton}" />
                    <Grid Name="btn_SelectLinkMode"
                          Margin="5,0,0,10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom"
                          Visibility="Hidden">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="DemiBold"
                                   Foreground="White"
                                   Text="Link Mode: " />
                        <RadioButton Name="rdo_btn_ANT"
                                     Grid.Column="1"
                                     HorizontalAlignment="Left"
                                     Panel.ZIndex="1"
                                     Content="ANT"
                                     FontWeight="DemiBold"
                                     Foreground="White"
                                     GroupName="LinkMode">
                            <RadioButton.LayoutTransform>
                                <ScaleTransform ScaleX="1.3"
                                                ScaleY="1.3" />
                            </RadioButton.LayoutTransform>
                        </RadioButton>
                        <RadioButton Name="rdo_btn_BT"
                                     Grid.Column="2"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     Panel.ZIndex="1"
                                     Content="BT"
                                     FontWeight="DemiBold"
                                     Foreground="White"
                                     GroupName="LinkMode">
                            <RadioButton.LayoutTransform>
                                <ScaleTransform ScaleX="1.3"
                                                ScaleY="1.3" />
                            </RadioButton.LayoutTransform>
                        </RadioButton>
                    </Grid>

                </Grid>
                <Button Name="btn_Start"
                        Grid.Row="2"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Click="clk_Start"
                        Content="Start Stream"
                        IsEnabled="False"
                        Margin="1,1,1,99"
                        Style="{StaticResource BasicStreamingButton}" />
                <Button Name="btn_Stop"
                        Grid.Row="2"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Margin="1,2,1,99"
                        Click="clk_Stop"
                        Content="Stop Stream"
                        IsEnabled="False"
                        Style="{StaticResource BasicStreamingButton}" />
                <Button Name="btn_Export"
                        Grid.Row="3"
                        Grid.RowSpan="2"
                        Grid.ColumnSpan="2"
                        Margin="1,3,1,98"
                        Click="clk_Export"
                        Content="Export Data to CSV"
                        IsEnabled="False"
                        Style="{StaticResource BasicStreamingButton}" />
                <Button Name="btn_Disarm"
                        Grid.Row="4"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="1,4,1,0"
                        Click="clk_Disarm"
                        Content="Disarm Pipeline"
                        IsEnabled="False"
                        Style="{StaticResource BasicStreamingButton}" />
            </Grid>
        </Border>
        <Grid Name="MainPanel"
              Grid.Row="0"
              Grid.Column="1" />
        <Grid Name="MessagePanel"
              Grid.Row="1"
              Grid.Column="0" 
              Grid.ColumnSpan="3"
              HorizontalAlignment="Center"
              
              />
        <Grid Name="SecondaryPanel"
              Grid.Row="0"
              Grid.RowSpan="2"
              Grid.Column="2" />
    </Grid>
</UserControl>